# EditorConfig is awesome: https://EditorConfig.org

root = true

[*]
indent_style = space
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.{java,xml,yml,yaml}]
indent_size = 2

[*.{py}]
indent_size = 4

[*.{ts,tsx,js,jsx,json,json5}]
indent_size = 2

[*.{md,rst}]
trim_trailing_whitespace = false

[Makefile]
indent_style = tab
