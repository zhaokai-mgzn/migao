# ============================================================
# AI Agent Service 环境变量配置模板
# 复制此文件为 .env 并填入实际值
# 配置架构：main.tf locals（唯一真相源）→ SAE → .env（本地开发镜像）
# ============================================================

# 应用基础配置
APP_NAME=ai-agent-service
APP_VERSION=1.0.0
DEBUG=true
API_PREFIX=/api

# 服务器配置
HOST=0.0.0.0
PORT=8000

# PostgreSQL 配置
DATABASE_URL=postgresql+asyncpg://app_user:your_password@localhost:5432/ai_customer_service

# Redis 配置
REDIS_URL=redis://localhost:6379/0

# ===== 以下为必填项 =====

# 主 LLM 配置（DeepSeek V4 Pro）
PRIMARY_API_KEY=your_deepseek_api_key_here
PRIMARY_BASE_URL=https://api.deepseek.com/v1
PRIMARY_MODEL=deepseek-chat
PRIMARY_FAST_MODEL=deepseek-chat

# 视觉模型配置（MiniMax M3）
VISION_API_KEY=your_minimax_api_key_here
VISION_BASE_URL=https://api.minimaxi.com/v1
VISION_MODEL=minimax-m3

# MiniMax API Key（兼容旧配置）
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_BASE_URL=https://api.minimaxi.com/v1
MINIMAX_MODEL=minimax-m3
MINIMAX_VISION_MODEL=minimax-m3

# Admin API 服务地址
ADMIN_API_BASE_URL=http://admin-api:8080

# Service Token
SERVICE_TOKEN=your_service_token_here

# JWT 公钥
JWT_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\nYOUR_KEY\n-----END PUBLIC KEY-----

# 物流查询 API
LOGISTICS_API_URL=https://wuliu.market.alicloudapi.com/kdi
LOGISTICS_APPCODE=your_appcode_here

# SSE / CORS
SSE_TIMEOUT=300
SSE_PING_INTERVAL=30
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# OSS 双 Bucket
OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
OSS_ACCESS_KEY_ID=your_oss_access_key_id
OSS_ACCESS_KEY_SECRET=your_oss_access_key_secret
OSS_PERMANENT_BUCKET=ai-customer-service-admin-dev
OSS_TEMPORARY_BUCKET=ai-customer-service-chat-dev

# ===== 以下有默认值，按需修改 =====

# 语义缓存
# SEMANTIC_CACHE_ENABLED=true

# Reranker
# RERANK_ENABLED=true

# 模型路由与成本
# LLM_ENABLE_MODEL_ROUTING=true
# LLM_MONTHLY_BUDGET_CNY=500.0
