# ============================================================
# AI Agent Service 环境变量配置模板
# 复制此文件为 .env 并填入实际值
# 配置架构：main.tf locals（唯一真相源）→ SAE → .env（本地开发镜像）
# ============================================================

# 应用基础配置
APP_NAME=ai-agent-service
APP_VERSION=1.0.0
DEBUG=true
API_PREFIX=/api

# 服务器配置
HOST=0.0.0.0
PORT=8000

# PostgreSQL 配置
# 格式: postgresql+asyncpg://用户名:密码@主机:端口/数据库名
DATABASE_URL=postgresql+asyncpg://app_user:your_password@localhost:5432/ai_customer_service

# Redis 配置
# 格式: redis://主机:端口/数据库索引
REDIS_URL=redis://localhost:6379/0

# ===== 以下为必填项（无默认值，漏配即报错）=====

# 阿里云百炼 LLM 配置
# 获取地址: https://bailian.console.aliyun.com/ → API-KEY 管理
DASHSCOPE_API_KEY=your_dashscope_api_key_here
DASHSCOPE_BASE_URL=https://token-plan.cn-beijing.maas.aliyuncs.com/compatible-mode/v1
DASHSCOPE_MODEL=qwen3.7-max
DASHSCOPE_EMBEDDING_MODEL=text-embedding-v3

# DashVector 向量数据库配置
# 获取地址: https://dashvector.console.aliyun.com/
DASHVECTOR_API_KEY=your_dashvector_api_key_here
DASHVECTOR_ENDPOINT=your_dashvector_endpoint_here
DASHVECTOR_COLLECTION=ai_customer_service

# Admin API 服务地址（内部调用）
# Docker 环境使用服务名: http://admin-api:8080
# 本地开发使用: http://localhost:8080
ADMIN_API_BASE_URL=http://admin-api:8080

# Service Token（用于调用 admin-api）
# 需与 admin-api 中配置的 service.token.secret 一致
SERVICE_TOKEN=your_service_token_here

# JWT 公钥（用于验证用户 Token）
# 从 admin-api 的 RSA 公钥获取，格式为 PEM 字符串
JWT_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\nMIIBIjANBgkqhkiG9w0BAQEFAAOCAQ8AMIIBCgKCAQEA...\n-----END PUBLIC KEY-----

# 物流查询 API（阿里云市场）
# 购买地址: https://market.aliyun.com/ 搜索"快递物流查询"
LOGISTICS_API_URL=https://wuliu.market.alicloudapi.com/kdi
LOGISTICS_APPCODE=your_appcode_here

# SSE 配置
SSE_TIMEOUT=300
SSE_PING_INTERVAL=30

# CORS 允许的前端域名（逗号分隔，生产环境需修改）
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ===== 以下有默认值，按需修改 =====

# 意图分类模型（qwen3.6-flash：轻量快速，代码中自动关闭思考模式）
# INTENT_MODEL=qwen3.6-flash

# 图片识别模型
# DASHSCOPE_VISION_MODEL=qwen3.6-plus
# DASHSCOPE_VISION_ENABLED=true

# 图片 URL 重写：CDN 域名 → OSS 公网域名
# DashScope Vision API 需要公网可访问的 HTTPS URL，
# 但 admin-api 返回的图片 URL 使用 CDN 域名，该域名可能未正确配置 DNS/CDN。
# 配置后将自动替换：IMAGE_URL_REWRITE_FROM → IMAGE_URL_REWRITE_TO
# IMAGE_URL_REWRITE_FROM=https://admin.migaozn.com
# IMAGE_URL_REWRITE_TO=https://ai-customer-service-admin-dev.oss-cn-hangzhou.aliyuncs.com

# 语义缓存
# SEMANTIC_CACHE_ENABLED=true

# Reranker
# RERANK_ENABLED=true
# RERANK_MODEL=gte-rerank

# 模型路由与成本
# LLM_ENABLE_MODEL_ROUTING=true
# LLM_COST_TRACKING_ENABLED=true
# LLM_MONTHLY_BUDGET_CNY=500.0
