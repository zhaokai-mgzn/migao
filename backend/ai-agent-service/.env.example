# ============================================================
# AI Agent Service 环境变量配置模板
# 复制此文件为 .env 并填入实际值
# ============================================================

# 应用基础配置
APP_NAME=ai-agent-service
APP_VERSION=1.0.0
DEBUG=false
API_PREFIX=/api

# 服务器配置
HOST=0.0.0.0
PORT=8000

# PostgreSQL 配置
# 格式: postgresql+asyncpg://用户名:密码@主机:端口/数据库名
DATABASE_URL=postgresql+asyncpg://app_user:your_password@localhost:5432/ai_customer_service

# Redis 配置
# 格式: redis://主机:端口/数据库索引
REDIS_URL=redis://localhost:6379/0

# 阿里云百炼 LLM 配置
# 获取地址: https://dashscope.aliyun.com/
DASHSCOPE_API_KEY=your_dashscope_api_key_here
DASHSCOPE_MODEL=qwen-turbo
DASHSCOPE_EMBEDDING_MODEL=text-embedding-v3

# DashVector 配置（向量数据库）
# 获取地址: https://dashvector.console.aliyun.com/
DASHVECTOR_API_KEY=your_dashvector_api_key_here
DASHVECTOR_ENDPOINT=your_dashvector_endpoint_here
DASHVECTOR_COLLECTION=ai_customer_service

# Admin API 服务地址（内部调用）
# Docker 环境使用服务名: http://admin-api:8080
# 本地开发使用: http://localhost:8080
ADMIN_API_BASE_URL=http://admin-api:8080

# Service Token（用于调用 admin-api）
# 需与 admin-api 中配置的 service.token.secret 一致
SERVICE_TOKEN=your_service_token_here

# JWT 公钥（用于验证用户 Token）
# 从 admin-api 的 RSA 公钥获取，格式为 PEM 字符串
JWT_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\nMIIBIjANBgkqhkiG9w0BAQEFAAOCAQ8AMIIBCgKCAQEA...\n-----END PUBLIC KEY-----

# 物流查询 API（阿里云市场）
# 购买地址: https://market.aliyun.com/ 搜索“快递物流查询”
LOGISTICS_API_URL=https://wuliu.market.alicloudapi.com/kdi
LOGISTICS_APPCODE=your_appcode_here

# SSE 配置
SSE_TIMEOUT=300
SSE_PING_INTERVAL=30

# CORS 允许的前端域名（逗号分隔，生产环境需修改）
CORS_ALLOWED_ORIGINS=https://admin.migaozn.com
