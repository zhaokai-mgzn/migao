# 数据库配置
RDS_HOST=localhost
RDS_PORT=5432
RDS_DB=ai_customer_service
RDS_USER=app_user
RDS_PASSWORD=your_password

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT 配置（RSA 私钥和公钥路径）
JWT_PRIVATE_KEY=classpath:rsa/private.pem
JWT_PUBLIC_KEY=classpath:rsa/public.pem
COOKIE_DOMAIN=localhost

# Service Token
SERVICE_TOKEN_SECRET=your-service-token-secret

# 阿里云 OSS 配置
OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
OSS_ACCESS_KEY_ID=your-access-key-id
OSS_ACCESS_KEY_SECRET=your-access-key-secret
OSS_BUCKET_NAME=your-bucket-name
OSS_URL_PREFIX=https://your-bucket.oss-cn-hangzhou.aliyuncs.com

# 微信小程序配置
WECHAT_MINI_APPID=
WECHAT_MINI_SECRET=

# 阿里云短信服务
ALIYUN_SMS_ACCESS_KEY_ID=
ALIYUN_SMS_ACCESS_KEY_SECRET=
ALIYUN_SMS_SIGN_NAME=你的短信签名
ALIYUN_SMS_TEMPLATE_CODE=你的模板Code

# CORS 允许的前端域名（逗号分隔，生产环境需修改）
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,https://admin.migaozn.com
