# 开发环境配置（本地开发默认值）

# Java admin-api 后端地址
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# Python ai-agent-service 地址
NEXT_PUBLIC_AI_API_BASE_URL=http://localhost:8001

# OSS 静态资源域名（开发环境也用线上 OSS）
NEXT_PUBLIC_OSS_DOMAIN=https://mgzn-admin.oss-cn-hangzhou.aliyuncs.com

# Cookie 域名（本地开发不设置，使用默认）
NEXT_PUBLIC_COOKIE_DOMAIN=
