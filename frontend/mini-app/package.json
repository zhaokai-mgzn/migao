{
  "name": "mini-app",
  "version": "1.0.0",
  "private": true,
  "description": "AI客服微信小程序",
  "templateInfo": {
    "name": "default",
    "typescript": true,
    "css": "sass"
  },
  "scripts": {
    "build:weapp": "taro build --type weapp",
    "dev:weapp": "npm run build:weapp -- --watch",
    "build:swan": "taro build --type swan",
    "dev:swan": "npm run build:swan -- --watch",
    "build:alipay": "taro build --type alipay",
    "dev:alipay": "npm run build:alipay -- --watch",
    "build:tt": "taro build --type tt",
    "dev:tt": "npm run build:tt -- --watch",
    "build:h5": "taro build --type h5",
    "dev:h5": "npm run build:h5 -- --watch",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "browserslist": [
    "last 3 versions",
    "Android >= 4.1",
    "ios >= 8"
  ],
  "dependencies": {
    "@tarojs/components": "3.6.40",
    "@tarojs/helper": "3.6.40",
    "@tarojs/plugin-framework-react": "3.6.40",
    "@tarojs/plugin-platform-alipay": "3.6.40",
    "@tarojs/plugin-platform-swan": "3.6.40",
    "@tarojs/plugin-platform-tt": "3.6.40",
    "@tarojs/plugin-platform-weapp": "3.6.40",
    "@tarojs/react": "3.6.40",
    "@tarojs/runtime": "3.6.40",
    "@tarojs/shared": "3.6.40",
    "@tarojs/taro": "3.6.40",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@babel/core": "^7.8.0",
    "@babel/runtime": "^7.7.7",
    "@tarojs/cli": "3.6.40",
    "@tarojs/webpack5-runner": "3.6.40",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/jest": "^29.5.14",
    "@types/react": "^18.2.0",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "babel-preset-taro": "3.6.40",
    "eslint": "^8.41.0",
    "eslint-config-taro": "3.6.40",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "postcss": "^8.4.18",
    "sass": "^1.69.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5.1.0",
    "webpack": "5.78.0"
  }
}
